{
  "name": "llm-ide",
  "displayName": "llm-ide",
  "description": "Local LLM powered IDE",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "llm-ide.openChat",       "title": "LLM IDE: Open Chat" },
      { "command": "llm-ide.buildIndex",     "title": "LLM IDE: Build Code Index" },
      { "command": "llm-ide.fixBuildError",  "title": "LLM IDE: Fix Build Error (Agent)" }
    ],
    "viewsContainers": {
      "activitybar": [{ "id": "llm-ide-sidebar", "title": "LLM IDE", "icon": "$(robot)" }]
    },
    "views": {
      "llm-ide-sidebar": [{ "type": "webview", "id": "llm-ide.chatPanel", "name": "Chat" }]
    },
    "keybindings": [{ "command": "llm-ide.openChat", "key": "cmd+shift+l" }],
    "configuration": {
      "title": "LLM IDE",
      "properties": {
        "llm-ide.localModel": {
          "type": "string",
          "default": "qwen2.5-coder:32b",
          "description": "Ollama 로컬 모델 이름"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
